@startuml use_case
title Diagramme de cas d'utilisation - Club Sportif

left to right direction

actor Admin

rectangle "Application Gestion Club Sportif" {
  usecase "Gérer les Membres" as UC1
  usecase "Ajouter un Membre" as UC1_1
  usecase "Modifier un Membre" as UC1_2
  usecase "Supprimer un Membre" as UC1_3

  usecase "Gérer les Abonnements" as UC2
  usecase "Ajouter un Abonnement" as UC2_1
  usecase "Renouveler un Abonnement" as UC2_2
  usecase "Annuler un Abonnement" as UC2_3

  usecase "Consulter les Statistiques" as UC3

  usecase "Exporter les Données" as UC4
}

Admin --> UC1
Admin --> UC2
Admin --> UC3
Admin --> UC4

UC1 <.. UC1_1 : <<include>>
UC1 <.. UC1_2 : <<include>>
UC1 <.. UC1_3 : <<include>>

UC2 <.. UC2_1 : <<include>>
UC2 <.. UC2_2 : <<include>>
UC2 <.. UC2_3 : <<include>>

@enduml
